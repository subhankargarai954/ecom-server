# .env

# DB_USER = "postgres"
# DB_HOST = "localhost"
# DB_NAME = "ecomdb"
# DB_PASSWORD = "0000"
# DB_PORT = 5421
PORT=
JWT_SECRET=

# Neon PostgreSQL connection string (from https://console.neon.tech)
DATABASE_URL=

# Cloudinary — add your credentials from cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin setup key — used to create the first admin account via POST /admin/api/auth/setup
ADMIN_SETUP_KEY=

# Razorpay — leave blank to run online payments in SIMULATION mode (testable now).
# Get test keys at https://dashboard.razorpay.com → Settings → API Keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Twilio SMS + WhatsApp — leave blank to run notifications in SIMULATION mode
# (messages are logged to the console & recorded in message_logs, nothing is sent).
# Get credentials at https://console.twilio.com → Account Info.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
# WhatsApp sender — this is the shared Twilio SANDBOX number, NOT your own.
# (Your number +91… is the RECIPIENT and must "join" the sandbox first.)
TWILIO_WHATSAPP_FROM=

# Default country code for stored 10-digit phone numbers.
SMS_COUNTRY_CODE=
# Customer portal base URL — used to build product links inside messages.
CLIENT_BASE_URL=
# Store name shown in messages & invoices.
STORE_NAME=
